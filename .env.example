# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para el stack de Temporal.io
# Copia este archivo como .env y ajusta los valores para producción
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=temporal
POSTGRES_PASSWORD=cambiar_en_produccion_123!
POSTGRES_DB=temporal

# ── Temporal Server ───────────────────────────────────────────────────────────
TEMPORAL_NAMESPACE=default
# En producción, usa la IP/dominio del servidor (para healthcheck externo)
TEMPORAL_BROADCAST_ADDRESS=temporal

# ── Temporal Web UI ───────────────────────────────────────────────────────────
# Dominio desde el que accederás a la UI (para CORS)
TEMPORAL_UI_CORS=https://temporal-ui.tudominio.com

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_REPLICAS=1
NODE_ENV=production
